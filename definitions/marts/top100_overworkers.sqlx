config {
   type: "table",
   schema: "marts"
}

SELECT
    taxi_id,
    COUNT (*) AS total_trips,
    TIMESTAMP_DIFF(MAX(trip_end_timestamp), MIN(trip_start_timestamp), HOUR) AS total_active_hours,
    ROUND(SUM(trip_seconds) / 3600, 2) AS total_trip_hours
FROM
  ${ref("stg_taxi_trips_1")}
GROUP BY taxi_id
ORDER BY total_trip_hours DESC
LIMIT 100