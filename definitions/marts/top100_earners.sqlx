config {
   type: "table",
   schema: "marts"
}

SELECT
    taxi_id,
    ROUND(SUM(trip_total), 2) AS total_earned
FROM
  ${ref("stg_taxi_trips")}
WHERE trip_date >=(
   SELECT DATE_SUB(MAX(trip_date), INTERVAL 3 MONTH)
   FROM
      ${ref("stg_taxi_trips")}
)
GROUP BY taxi_id
ORDER BY total_earned DESC
LIMIT 100